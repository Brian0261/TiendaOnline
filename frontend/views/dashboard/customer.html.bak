<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title>Dashboard Cliente  Bodega Luchito</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.0.0/css/all.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/assets/css/styles.css" />
    <link rel="stylesheet" href="/assets/css/dashboard.css" />
    <style>
      .nav-dashboard {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.07);
        margin-bottom: 32px;
        padding: 0.5rem 1.2rem;
        display: flex;
        gap: 1.5rem;
      }
      .nav-dashboard .nav-link {
        font-weight: 500;
        color: #343a40;
        border-bottom: 2.5px solid transparent;
        transition: all 0.16s;
        padding-bottom: 5px;
      }
      .nav-dashboard .nav-link.active,
      .nav-dashboard .nav-link:hover {
        color: #dc3545;
        border-bottom: 2.5px solid #dc3545;
        background: none;
      }
      @media (max-width: 700px) {
        .nav-dashboard {
          flex-direction: column;
          gap: 0.6rem;
          align-items: flex-start;
        }
      }
    </style>
  </head>
  <body>
    <!--  NAVBAR  -->
    <div id="navbar-container"></div>

    <main class="container py-4" style="max-width: 900px">
      <h1 class="mb-3">Hola, <span id="cliente-nombre">Cliente</span> </h1>
      <nav class="nav-dashboard mb-3">
        <a href="#" class="nav-link" id="tab-profile"><i class="fa fa-user-circle me-1"></i> Datos personales</a>
        <a href="#" class="nav-link" id="tab-orders"><i class="fa fa-shopping-bag me-1"></i> Mis compras</a>
        <a href="#" class="nav-link text-danger" id="logout-btn"><i class="fa fa-sign-out-alt me-1"></i> Cerrar sesión</a>
      </nav>

      <!-- DATOS PERSONALES -->
      <section id="section-profile" style="display: none">
        <form id="profile-form" class="row gy-3 mb-4">
          <div class="col-md-6">
            <label for="pf-nombre" class="form-label">Nombre</label>
            <input type="text" class="form-control" id="pf-nombre" name="nombre" required />
          </div>
          <div class="col-md-6">
            <label for="pf-apellido" class="form-label">Apellido</label>
            <input type="text" class="form-control" id="pf-apellido" name="apellido" required />
          </div>
          <div class="col-md-6">
            <label for="pf-email" class="form-label">Correo electrónico</label>
            <input type="email" class="form-control" id="pf-email" name="email" readonly />
          </div>
          <div class="col-md-6">
            <label for="pf-telefono" class="form-label">Teléfono</label>
            <input type="text" class="form-control" id="pf-telefono" name="telefono" />
          </div>
          <div class="col-12">
            <label for="pf-direccion" class="form-label">Dirección principal</label>
            <input type="text" class="form-control" id="pf-direccion" name="direccion_principal" />
          </div>
          <div class="col-12 text-end">
            <button type="submit" class="btn btn-primary">Actualizar datos</button>
          </div>
        </form>
      </section>

      <!-- MIS COMPRAS -->
      <section id="section-orders" style="display: none">
        <h4>Mis Compras Online</h4>
        <div id="orders-list"></div>
      </section>
    </main>

    <footer class="bg-dark text-white text-center py-3">
      <small>&copy; 2025 Bodega Luchito. Todos los derechos reservados.</small>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Carga el navbar y luego ejecuta main.js para mostrar el avatar -->
    <script type="module">
      import { loadPartial } from "/assets/js/shared/loadPartials.js";
      import { verificarSesion } from "/assets/js/main.js";
      import { updateCartCounter } from "/assets/js/shared/cartUtils.js";

      loadPartial("#navbar-container", "/partials/navbar.html").then(() => {
        verificarSesion();
        updateCartCounter();
      });
    </script>
    <script type="module" src="/assets/js/dashboard/customer.js"></script>
    <script type="module" src="/assets/js/shared/toast.js"></script>
  </body>
</html>

