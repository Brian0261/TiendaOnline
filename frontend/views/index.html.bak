<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bodega Luchito - Tienda en Línea</title>

    <!-- Bootstrap CSS (CDN) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Font Awesome (solo CSS por CDN) -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.0.0/css/all.min.css" />

    <!-- Tus estilos locales -->
    <link rel="stylesheet" href="/assets/css/styles.css" />

    <style>
      :root {
        --primary-color: #dc3545;
        --secondary-color: #343a40;
        --light-color: #f8f9fa;
        --dark-color: #212529;
        --accent-color: #ffc107;
      }

      body {
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        color: var(--dark-color);
      }

      .hero-section {
        background: linear-gradient(rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.7)), url(/assets/images/banner-bodega.jpg);
        background-size: cover;
        background-position: center;
        min-height: 400px;
        display: flex;
        align-items: center;
        position: relative;
      }

      .hero-content {
        position: relative;
        z-index: 2;
      }

      .category-card {
        transition: transform 0.3s ease;
        border: none;
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        height: 100%;
      }

      .category-card:hover {
        transform: translateY(-5px);
      }

      .category-icon {
        font-size: 2.5rem;
        margin-bottom: 1rem;
        color: var(--primary-color);
      }

      .product-card {
        border: none;
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        transition: all 0.3s ease;
        margin-bottom: 20px;
        height: 100%;
      }

      .product-card:hover {
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.2);
      }

      .product-img {
        max-height: 150px;
        object-fit: contain;
        width: 100%;
      }

      .btn-primary-custom {
        background-color: var(--primary-color);
        border-color: var(--primary-color);
        color: white;
      }

      .btn-primary-custom:hover {
        background-color: #c82333;
        border-color: #bd2130;
      }

      .text-primary-custom {
        color: var(--primary-color) !important;
      }

      .badge-custom {
        background-color: var(--primary-color);
      }

      .feature-box {
        background-color: white;
        border-radius: 10px;
        padding: 30px;
        text-align: center;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        height: 100%;
        transition: transform 0.3s ease;
      }

      .feature-box:hover {
        transform: translateY(-5px);
      }

      .feature-icon {
        font-size: 2.5rem;
        color: var(--primary-color);
        margin-bottom: 1rem;
      }

      .text-overlay {
        text-shadow: 1px 1px 3px rgba(0, 0, 0, 0.8);
      }
    </style>
  </head>
  <body>
    <!-- NAVBAR Y LOGIN MODAL (se cargan como parciales) -->
    <div id="navbar-container"></div>
    <div id="modal-container"></div>

    <!-- HERO -->
    <section class="hero-section text-white py-5">
      <div class="container hero-content">
        <div class="row align-items-center">
          <div class="col-lg-6">
            <h1 class="display-4 fw-bold mb-4 text-overlay">Los mejores productos para tu hogar</h1>
            <p class="lead mb-4 text-overlay">Encuentra todo lo que necesitas a precios de bodega con la comodidad de comprar desde casa.</p>
            <div class="d-flex gap-3">
              <a href="products/catalog.html" class="btn btn-light btn-lg px-4 py-2 fw-bold">Ver Catálogo</a>
              <a href="auth/register.html" class="btn btn-outline-light btn-lg px-4 py-2 fw-bold">Regístrate Gratis</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CATEGORÍAS -->
    <section class="py-5 bg-light">
      <div class="container">
        <div class="text-center mb-5">
          <h2 class="fw-bold">Explora Nuestras Categorías</h2>
          <p class="text-muted">Encuentra lo que necesitas organizado por categorías</p>
        </div>
        <div class="row g-4">
          <div class="col-md-3">
            <a href="products/catalog.html?category=1" class="text-decoration-none">
              <div class="category-card card h-100 text-center p-4">
                <div class="category-icon"><i class="fas fa-shopping-basket"></i></div>
                <h3 class="h5">Abarrotes</h3>
                <p class="text-muted">Arroz, aceite, fideos y más</p>
              </div>
            </a>
          </div>
          <div class="col-md-3">
            <a href="products/catalog.html?category=2" class="text-decoration-none">
              <div class="category-card card h-100 text-center p-4">
                <div class="category-icon"><i class="fas fa-wine-bottle"></i></div>
                <h3 class="h5">Bebidas</h3>
                <p class="text-muted">Refrescos, jugos y licores</p>
              </div>
            </a>
          </div>
          <div class="col-md-3">
            <a href="products/catalog.html?category=3" class="text-decoration-none">
              <div class="category-card card h-100 text-center p-4">
                <div class="category-icon"><i class="fas fa-cheese"></i></div>
                <h3 class="h5">Lácteos</h3>
                <p class="text-muted">Leche, yogurt, queso y más</p>
              </div>
            </a>
          </div>
          <div class="col-md-3">
            <a href="products/catalog.html?category=4" class="text-decoration-none">
              <div class="category-card card h-100 text-center p-4">
                <div class="category-icon"><i class="fas fa-cookie"></i></div>
                <h3 class="h5">Snacks</h3>
                <p class="text-muted">Galletas, chocolates y más</p>
              </div>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- PRODUCTOS DESTACADOS -->
    <section class="py-5">
      <div class="container">
        <div class="text-center mb-5">
          <h2 class="fw-bold">Productos Destacados</h2>
          <p class="text-muted">Los productos más populares de nuestra bodega</p>
        </div>
        <div class="row g-4" id="featured-product-grid"></div>
        <div class="text-center mt-4">
          <a href="products/catalog.html" class="btn btn-primary-custom btn-lg px-4">Ver todos los productos</a>
        </div>
      </div>
    </section>

    <!-- VENTAJAS -->
    <section class="py-5 bg-light">
      <div class="container">
        <div class="text-center mb-5">
          <h2 class="fw-bold">¿Por qué elegir Bodega Luchito?</h2>
          <p class="text-muted">Las razones para comprar con nosotros</p>
        </div>
        <div class="row g-4">
          <div class="col-md-4">
            <div class="feature-box">
              <div class="feature-icon"><i class="fas fa-truck"></i></div>
              <h3>Envío Rápido</h3>
              <p class="text-muted">Recibe tus productos en menos de 24 horas en tu domicilio.</p>
            </div>
          </div>
          <div class="col-md-4">
            <div class="feature-box">
              <div class="feature-icon"><i class="fas fa-tag"></i></div>
              <h3>Precios de Bodega</h3>
              <p class="text-muted">Los mejores precios directos de nuestra bodega a tu casa.</p>
            </div>
          </div>
          <div class="col-md-4">
            <div class="feature-box">
              <div class="feature-icon"><i class="fas fa-shield-alt"></i></div>
              <h3>Pago Seguro</h3>
              <p class="text-muted">Múltiples métodos de pago con total seguridad.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA REGISTRO -->
    <section class="py-5 bg-primary-custom">
      <div class="container text-center">
        <h2 class="fw-bold mb-4">¿Aún no tienes una cuenta?</h2>
        <p class="lead mb-4">Regístrate ahora y obtén acceso a ofertas exclusivas y descuentos especiales.</p>
        <a href="auth/register.html" class="btn btn-primary-custom btn-lg px-4">Regístrate Gratis</a>
      </div>
    </section>

    <!-- FOOTER -->
    <div id="footer-container"></div>

    <!-- SCRIPTS -->
    <!-- Bootstrap Bundle (incluye Popper) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Carga de parciales (navbar/footer) y menú de usuario -->
    <script type="module" src="/assets/js/shared/partials-init.js" defer></script>
    <!-- Si luego necesitas más scripts, agrégalos aquí con type="module" y defer -->
  </body>
</html>



