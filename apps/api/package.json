{
  "name": "minimarket-express-backend",
  "version": "1.0.0",
  "description": "Backend para la tienda en línea Minimarket Express",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "nodemon --watch . --ext ts --exec ts-node server.ts",
    "test": "npm run build && cross-env NODE_ENV=test jest dist/__tests__ --detectOpenHandles",
    "test:bdd": "cucumber-js --require-module ts-node/register --require features/steps/**/*.ts"
  },
  "keywords": [],
  "author": "Equipo Minimarket Express",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.0",
    "jsonwebtoken": "^9.0.1",
    "morgan": "^1.10.0",
    "multer": "^2.0.1",
    "pg": "^8.11.5"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^10.0.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.23",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.2",
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
